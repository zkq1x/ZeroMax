import { Button, VerticalBox } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "ZeroMax";
    min-width: 800px;
    min-height: 500px;
    preferred-width: 1000px;
    preferred-height: 700px;

    in-out property <string> status: "Ready";
    in-out property <bool> busy: false;
    callback connect-clicked();

    VerticalBox {
        alignment: center;
        spacing: 16px;

        Text {
            text: "ZeroMax";
            font-size: 32px;
            font-weight: 600;
            horizontal-alignment: center;
        }

        Text {
            text: "Privacy-focused MAX client";
            font-size: 14px;
            color: #888;
            horizontal-alignment: center;
        }

        Rectangle { height: 24px; }

        Text {
            text: root.status;
            font-size: 13px;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        HorizontalLayout {
            alignment: center;
            Button {
                text: root.busy ? "Connecting…" : "Test connect to MAX";
                enabled: !root.busy;
                clicked => { root.connect-clicked(); }
            }
        }
    }
}
