import { Button, LineEdit, VerticalBox, HorizontalBox, ListView, ScrollView } from "std-widgets.slint";

export enum Screen {
    bootstrap,
    login-choose,
    login-phone,
    login-code,
    login-2fa,
    login-qr,
    authed,
}

export struct ChatRowData {
    id-text: string,    // i64 as string (Slint structs have no i64)
    title: string,
    preview: string,
    time: string,
    initial: string,
    avatar-bg: color,
}

component Title inherits Text {
    font-size: 22px;
    font-weight: 600;
    horizontal-alignment: center;
}

component Subtitle inherits Text {
    font-size: 13px;
    color: #999;
    horizontal-alignment: center;
    wrap: word-wrap;
}

component ErrorBanner inherits Text {
    color: #e06060;
    font-size: 12px;
    horizontal-alignment: center;
    wrap: word-wrap;
}

component BootstrapView inherits Rectangle {
    VerticalBox {
        alignment: center;
        spacing: 12px;
        Title { text: "ZeroMax"; }
        Subtitle { text: "Restoring session…"; }
    }
}

component ChooseLoginView inherits Rectangle {
    callback choose-phone();
    callback choose-qr();

    VerticalBox {
        alignment: center;
        spacing: 16px;
        padding: 32px;

        Title { text: "Welcome to ZeroMax"; }
        Subtitle { text: "Choose how to sign in"; }

        Rectangle { height: 16px; }

        HorizontalBox {
            alignment: center;
            spacing: 12px;
            Button { text: "Phone + SMS"; clicked => { root.choose-phone(); } }
            Button { text: "QR code"; clicked => { root.choose-qr(); } }
        }
    }
}

component PhoneView inherits Rectangle {
    in property <bool> busy;
    in property <string> error-message;
    callback submit(string);
    callback back();

    VerticalBox {
        alignment: center;
        spacing: 12px;
        padding: 32px;

        Title { text: "Enter phone number"; }
        Subtitle { text: "We'll send a code via SMS"; }

        Rectangle { height: 8px; }

        HorizontalBox {
            alignment: center;
            phone-input := LineEdit {
                width: 280px;
                placeholder-text: "+7…";
                enabled: !root.busy;
                accepted(text) => { root.submit(text); }
            }
        }

        if root.error-message != "": ErrorBanner { text: root.error-message; }

        HorizontalBox {
            alignment: center;
            spacing: 8px;
            Button { text: "Back"; enabled: !root.busy; clicked => { root.back(); } }
            Button {
                text: root.busy ? "Sending…" : "Send code";
                primary: true;
                enabled: !root.busy;
                clicked => { root.submit(phone-input.text); }
            }
        }
    }
}

component CodeView inherits Rectangle {
    in property <bool> busy;
    in property <string> phone;
    in property <string> error-message;
    callback submit(string);
    callback back();

    VerticalBox {
        alignment: center;
        spacing: 12px;
        padding: 32px;

        Title { text: "Enter code"; }
        Subtitle { text: "Sent to " + root.phone; }

        Rectangle { height: 8px; }

        HorizontalBox {
            alignment: center;
            code-input := LineEdit {
                width: 200px;
                placeholder-text: "123456";
                input-type: number;
                enabled: !root.busy;
                accepted(text) => { root.submit(text); }
            }
        }

        if root.error-message != "": ErrorBanner { text: root.error-message; }

        HorizontalBox {
            alignment: center;
            spacing: 8px;
            Button { text: "Back"; enabled: !root.busy; clicked => { root.back(); } }
            Button {
                text: root.busy ? "Verifying…" : "Verify";
                primary: true;
                enabled: !root.busy;
                clicked => { root.submit(code-input.text); }
            }
        }
    }
}

component TwoFaView inherits Rectangle {
    in property <bool> busy;
    in property <string> hint;
    in property <string> error-message;
    callback submit(string);
    callback back();

    VerticalBox {
        alignment: center;
        spacing: 12px;
        padding: 32px;

        Title { text: "Two-factor password"; }
        Subtitle { text: root.hint != "" ? "Hint: " + root.hint : "Enter your 2FA password"; }

        Rectangle { height: 8px; }

        HorizontalBox {
            alignment: center;
            pwd-input := LineEdit {
                width: 280px;
                placeholder-text: "Password";
                input-type: password;
                enabled: !root.busy;
                accepted(text) => { root.submit(text); }
            }
        }

        if root.error-message != "": ErrorBanner { text: root.error-message; }

        HorizontalBox {
            alignment: center;
            spacing: 8px;
            Button { text: "Back"; enabled: !root.busy; clicked => { root.back(); } }
            Button {
                text: root.busy ? "Checking…" : "Sign in";
                primary: true;
                enabled: !root.busy;
                clicked => { root.submit(pwd-input.text); }
            }
        }
    }
}

component QrView inherits Rectangle {
    in property <image> qr;
    in property <string> status;
    in property <string> error-message;
    in property <bool> busy;
    callback back();

    VerticalBox {
        alignment: center;
        spacing: 12px;
        padding: 32px;

        Title { text: "Scan with MAX mobile"; }
        Subtitle { text: "Open MAX → Settings → Devices → Link device"; }

        Rectangle { height: 8px; }

        HorizontalBox {
            alignment: center;
            Rectangle {
                width: 256px;
                height: 256px;
                background: white;
                border-radius: 8px;
                Image {
                    source: root.qr;
                    width: 240px;
                    height: 240px;
                }
            }
        }

        Subtitle { text: root.status; }

        if root.error-message != "": ErrorBanner { text: root.error-message; }

        HorizontalBox {
            alignment: center;
            Button { text: "Back"; enabled: !root.busy; clicked => { root.back(); } }
        }
    }
}

component AvatarCircle inherits Rectangle {
    in property <string> initial;
    in property <color> bg;
    width: 40px;
    height: 40px;
    border-radius: 20px;
    background: bg;

    Text {
        text: root.initial;
        color: white;
        font-size: 16px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component ChatRow inherits Rectangle {
    in property <string> title;
    in property <string> preview;
    in property <string> time;
    in property <string> initial;
    in property <color> avatar-bg;
    in property <bool> selected;
    callback clicked();

    height: 64px;
    background: root.selected ? #2a2a2a : (ta.has-hover ? #232323 : transparent);

    ta := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 12px;

        AvatarCircle {
            initial: root.initial;
            bg: root.avatar-bg;
        }

        VerticalLayout {
            spacing: 2px;
            HorizontalLayout {
                Text {
                    text: root.title;
                    font-size: 14px;
                    font-weight: 500;
                    color: white;
                    overflow: elide;
                    horizontal-stretch: 1;
                }
                Text {
                    text: root.time;
                    font-size: 11px;
                    color: #888;
                    horizontal-alignment: right;
                }
            }
            Text {
                text: root.preview;
                font-size: 12px;
                color: #999;
                overflow: elide;
            }
        }
    }
}

component ChatListPane inherits Rectangle {
    in property <[ChatRowData]> chats;
    in property <int> selected-idx: -1;
    in property <string> account-name;
    callback chat-selected(int);
    callback logout();

    background: #1a1a1a;

    VerticalLayout {
        Rectangle {
            height: 56px;
            background: #1e1e1e;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                padding-top: 8px;
                padding-bottom: 8px;
                spacing: 8px;

                VerticalLayout {
                    horizontal-stretch: 1;
                    Text {
                        text: "Chats";
                        font-size: 16px;
                        font-weight: 600;
                        color: white;
                    }
                    Text {
                        text: root.account-name;
                        font-size: 11px;
                        color: #888;
                        overflow: elide;
                    }
                }
                Button {
                    text: "Sign out";
                    clicked => { root.logout(); }
                }
            }

            // Border at the bottom of the header
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: #2c2c2c;
            }
        }

        ListView {
            for item[idx] in root.chats: ChatRow {
                title: item.title;
                preview: item.preview;
                time: item.time;
                initial: item.initial;
                avatar-bg: item.avatar-bg;
                selected: idx == root.selected-idx;
                clicked => { root.chat-selected(idx); }
            }
        }
    }
}

component ConversationPlaceholder inherits Rectangle {
    background: #161616;
    VerticalBox {
        alignment: center;
        spacing: 8px;
        Title { text: "Select a chat"; }
        Subtitle { text: "Conversation view comes in Phase 5"; }
    }
}

component MainView inherits Rectangle {
    in property <[ChatRowData]> chats;
    in property <int> selected-idx: -1;
    in property <string> account-name;
    callback chat-selected(int);
    callback logout();

    HorizontalLayout {
        ChatListPane {
            width: 320px;
            chats: root.chats;
            selected-idx: root.selected-idx;
            account-name: root.account-name;
            chat-selected(idx) => { root.chat-selected(idx); }
            logout => { root.logout(); }
        }
        ConversationPlaceholder {
            horizontal-stretch: 1;
        }
    }
}

export component AppWindow inherits Window {
    title: "ZeroMax";
    min-width: 800px;
    min-height: 500px;
    preferred-width: 1000px;
    preferred-height: 700px;
    background: #121212;

    in-out property <Screen> screen: Screen.bootstrap;
    in-out property <bool> busy: false;
    in-out property <string> error-message: "";
    in-out property <string> phone: "";
    in-out property <string> two-fa-hint: "";
    in-out property <string> qr-status: "Waiting for scan…";
    in-out property <image> qr-image;
    in-out property <string> account-name: "";
    in-out property <[ChatRowData]> chats: [];
    in-out property <int> selected-chat-idx: -1;

    callback choose-phone();
    callback choose-qr();
    callback submit-phone(string);
    callback submit-code(string);
    callback submit-2fa(string);
    callback back-to-choose();
    callback logout();
    callback chat-selected(int);

    if root.screen == Screen.bootstrap: BootstrapView {
        width: 100%; height: 100%;
    }
    if root.screen == Screen.login-choose: ChooseLoginView {
        width: 100%; height: 100%;
        choose-phone => { root.choose-phone(); }
        choose-qr => { root.choose-qr(); }
    }
    if root.screen == Screen.login-phone: PhoneView {
        width: 100%; height: 100%;
        busy: root.busy;
        error-message: root.error-message;
        submit(p) => { root.submit-phone(p); }
        back => { root.back-to-choose(); }
    }
    if root.screen == Screen.login-code: CodeView {
        width: 100%; height: 100%;
        busy: root.busy;
        phone: root.phone;
        error-message: root.error-message;
        submit(c) => { root.submit-code(c); }
        back => { root.back-to-choose(); }
    }
    if root.screen == Screen.login-2fa: TwoFaView {
        width: 100%; height: 100%;
        busy: root.busy;
        hint: root.two-fa-hint;
        error-message: root.error-message;
        submit(p) => { root.submit-2fa(p); }
        back => { root.back-to-choose(); }
    }
    if root.screen == Screen.login-qr: QrView {
        width: 100%; height: 100%;
        qr: root.qr-image;
        status: root.qr-status;
        error-message: root.error-message;
        busy: root.busy;
        back => { root.back-to-choose(); }
    }
    if root.screen == Screen.authed: MainView {
        width: 100%; height: 100%;
        chats: root.chats;
        selected-idx: root.selected-chat-idx;
        account-name: root.account-name;
        chat-selected(idx) => { root.chat-selected(idx); }
        logout => { root.logout(); }
    }
}
